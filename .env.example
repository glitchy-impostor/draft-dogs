# Copy to .env.local for dev overrides, or set in your CI for production builds.

# Subpath that the built app lives under. For GitHub Pages, this is
# "/<repo-name>/" — e.g. "/draft-dogs-redesign/". Leave as "/" for Railway,
# Netlify, Cloudflare Pages, or any other root-hosted target.
VITE_BASE_PATH=/

# Absolute URL of the FastAPI backend. Leave blank to use same-origin (works
# with the Vite dev proxy and with single-origin deploys). For GH Pages +
# Railway, set this to your Railway URL, e.g. https://your-app.up.railway.app
VITE_API_URL=
